# =============================================================================
# TrueSight — Fichier de configuration serveur (exemple)
# -----------------------------------------------------------------------------
# Copiez ce fichier en « .env » à la racine du dépôt puis renseignez les
# valeurs réelles :
#     cp .env.example .env
#
# IMPORTANT :
#   - Le fichier .env NE doit JAMAIS être commité (il est dans .gitignore).
#   - Générez des secrets aléatoires forts (voir commandes ci-dessous).
#   - Toutes les variables marquées « OBLIGATOIRE » doivent être renseignées.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
# Connexion utilisée par SQLAlchemy (pilote psycopg 3 : « postgresql+psycopg »).
# Les identifiants doivent correspondre à POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB du service « db » dans docker-compose.yml.
# L'hôte « db » est le nom du service Compose (résolution DNS interne).
#
# PARTAGÉE avec le service « relay » : le relais bureau à distance lit cette même
# variable pour valider les jetons de session (table remote_sessions) via une
# requête SQL simple — pas d'ORM. Une seule valeur à maintenir, ici, pour les deux
# services « web » et « relay ».
DATABASE_URL=postgresql+psycopg://truesight:truesight@db:5432/truesight

# -----------------------------------------------------------------------------
# Secrets cryptographiques — OBLIGATOIRE
# -----------------------------------------------------------------------------
# SECRET_KEY : clé de signature des sessions Flask (cookies).
#   Générez une valeur aléatoire (NE PAS réutiliser l'exemple) :
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REMPLACEZ_MOI_par_une_cle_aleatoire_de_48_octets

# ENROLLMENT_TOKEN : secret partagé d'enrôlement, poussé aux agents par GPO.
#   Tout agent présentant ce token au 1er contact reçoit son token unique.
#   Générez une valeur aléatoire (NE PAS réutiliser l'exemple) :
#       python -c "import secrets; print(secrets.token_urlsafe(32))"
ENROLLMENT_TOKEN=REMPLACEZ_MOI_par_un_token_enrolement_aleatoire

# -----------------------------------------------------------------------------
# Compte administrateur initial — OBLIGATOIRE (créé au 1er démarrage)
# -----------------------------------------------------------------------------
# Si aucun utilisateur n'existe encore, ce compte admin est créé automatiquement
# au boot (seed.ensure_admin). Changez le mot de passe après la 1re connexion et
# activez la MFA (TOTP) depuis le dashboard.
ADMIN_EMAIL=admin@medicofi.fr
ADMIN_PASSWORD=ChangezMoiVraiment!

# -----------------------------------------------------------------------------
# Alertes — webhook n8n (optionnel)
# -----------------------------------------------------------------------------
# URL du webhook n8n recevant les alertes (PC hors-ligne, disque bas, CPU haut).
# Laissez VIDE pour désactiver complètement l'envoi d'alertes.
N8N_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Seuils & rétention
# -----------------------------------------------------------------------------
# Délai (en secondes) sans heartbeat au-delà duquel un poste est « offline ».
OFFLINE_THRESHOLD_SECONDS=300

# Durée de conservation des métriques (jours) ; au-delà, purge automatique.
METRICS_RETENTION_DAYS=90

# Seuil d'alerte « disque bas » : % d'espace libre en dessous duquel on alerte.
ALERT_DISK_LOW_PCT=10

# Seuil d'alerte « CPU saturé » : % d'utilisation CPU soutenue déclenchant l'alerte.
ALERT_CPU_HIGH_PCT=90

# -----------------------------------------------------------------------------
# Bureau à distance — relais WebSocket (service « relay »)
# -----------------------------------------------------------------------------
# Le relais NE nécessite AUCUNE variable supplémentaire obligatoire : il réutilise
# la même DATABASE_URL que le service « web » (voir tout en haut de ce fichier)
# pour valider les jetons de session « remote_sessions ». Rien à ajouter ici dans
# le cas standard.
#
# IMPORTANT — wss (WebSocket sécurisé) :
#   Le navigateur admin et l'agent se connectent en « wss:// » (WebSocket sur TLS).
#   Cela impose IMPÉRATIVEMENT :
#     1. un NOM DE DOMAINE public pointant vers le VPS (ex. parc.medicofi.fr) ;
#     2. un CERTIFICAT TLS valide pour ce domaine (Let's Encrypt via certbot,
#        cf. deploy/README.md) — un certificat auto-signé ou une simple adresse IP
#        feront échouer le handshake wss côté navigateur.
#   Les URL « ws_url » renvoyées par l'API sont construites depuis l'hôte public
#   (request.host_url, http->ws / https->wss, via ProxyFix) : le domaine et le
#   certificat ci-dessus doivent donc être correctement servis par nginx.
#
# Variables OPTIONNELLES (laissées commentées — valeurs par défaut convenables) :
#
#   Port d'écoute interne du relais dans son conteneur (défaut : 8765).
#   À ne changer QUE si vous l'alignez aussi dans docker-compose.yml (expose)
#   et dans deploy/nginx.conf (proxy_pass http://relay:8765).
# RELAY_PORT=8765
#
#   Fenêtre (en secondes) d'appariement d'un jeton de session : au-delà, le jeton
#   est considéré expiré et la connexion refusée (contrat : 60 s).
# RELAY_SESSION_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# Copilote IA (optionnel) — assistant de dépannage
# -----------------------------------------------------------------------------
# Active l'onglet « Copilote » sur la fiche poste : diagnostic en langage clair +
# propositions d'actions (que l'admin confirme). Laissez OPENAI_API_KEY VIDE pour
# désactiver complètement (aucun appel sortant, onglet masqué).
#
# Seule la télémétrie IT est envoyée au fournisseur (jamais les noms d'utilisateur,
# n° de série, adresses MAC ni IP — retirés côté serveur). Appels HTTPS sortants
# uniquement. Réservé aux administrateurs, chaque échange est audité (ai.query).
OPENAI_API_KEY=
#
# URL de base d'une API COMPATIBLE OpenAI. Par défaut l'API OpenAI publique.
# Pour rester 100 % auto-hébergé, pointez vers un Ollama local, ex. :
#   OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Modèle à utiliser (doit supporter le « function calling »). À régler selon votre
# clé / serveur (ex. gpt-4o, gpt-4.1, gpt-5-nano, ou un modèle Ollama comme llama3.1).
# OPENAI_MODEL=gpt-4o
#
# Nom du paramètre de limite de tokens envoyé à l'API. Les modèles récents OpenAI
# (GPT-5 / o-series, ex. gpt-5-nano) EXIGENT « max_completion_tokens » (défaut) et
# refusent « max_tokens » (erreur 400). Pour un serveur compatible OpenAI ancien /
# Ollama qui n'accepterait que « max_tokens », décommentez la ligne ci-dessous.
# OPENAI_MAX_TOKENS_PARAM=max_tokens
#
# Bornes de coût/latence. Pour un modèle « raisonnement » (GPT-5/o-series), les
# tokens de raisonnement s'imputent sur AI_MAX_TOKENS → prévoir large (>= 4000).
# AI_MAX_TOOL_ITERS=5
# AI_MAX_TOKENS=4000
